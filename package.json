{
  "name": "lexer-lab",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "In-browser Haskell lexer challenge for UFFS Aula 01 with a focused judge-first workflow.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "fuzz:locks": "node --experimental-strip-types --experimental-specifier-resolution=node ./scripts/fuzz-editor-locks.ts"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.18.6",
    "@codemirror/commands": "^6.8.1",
    "@codemirror/language": "^6.11.0",
    "@codemirror/legacy-modes": "^6.5.1",
    "@codemirror/search": "^6.7.0",
    "@codemirror/state": "^6.5.2",
    "@codemirror/view": "^6.38.1",
    "codemirror": "^6.0.2",
    "lucide-react": "^0.468.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.10.0",
    "@types/react": "^19.1.1",
    "@types/react-dom": "^19.1.1",
    "@vitejs/plugin-react": "^5.0.0",
    "jsdom": "^29.0.2",
    "typescript": "^5.7.0",
    "vite": "^7.0.0",
    "vitest": "^4.1.5"
  }
}
